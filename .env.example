# .env.example
# Copy this file to .env and update the values

# Required: Default M3U playlist URL
# The app will load this playlist automatically on first launch
# Users can still enter their own URLs
VITE_DEFAULT_M3U_URL=https://iptv-org.github.io/iptv/index.m3u

# Optional: App configuration
VITE_APP_NAME=StreamFlix
VITE_APP_VERSION=1.0.0